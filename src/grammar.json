{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "lean",
  "word": "_wordToken",
  "rules": {
    "module": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "module_doc_comment"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "moduleTk"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "prelude"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "import"
          }
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_command"
          }
        }
      ]
    },
    "moduleTk": {
      "type": "STRING",
      "value": "module"
    },
    "prelude": {
      "type": "STRING",
      "value": "prelude"
    },
    "import": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "public"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "meta"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "import"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "all"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          }
        }
      ]
    },
    "public": {
      "type": "STRING",
      "value": "public"
    },
    "meta": {
      "type": "STRING",
      "value": "meta"
    },
    "all": {
      "type": "STRING",
      "value": "all"
    },
    "_command": {
      "type": "SYMBOL",
      "name": "check"
    },
    "check": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "#check"
        },
        {
          "type": "FIELD",
          "name": "term",
          "content": {
            "type": "SYMBOL",
            "name": "_term"
          }
        }
      ]
    },
    "_term": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "identifier"
        },
        {
          "type": "SYMBOL",
          "name": "num_lit"
        },
        {
          "type": "SYMBOL",
          "name": "scientific_lit"
        },
        {
          "type": "SYMBOL",
          "name": "char_lit"
        },
        {
          "type": "SYMBOL",
          "name": "str_lit"
        },
        {
          "type": "SYMBOL",
          "name": "raw_string"
        },
        {
          "type": "SYMBOL",
          "name": "interpolated_str"
        },
        {
          "type": "SYMBOL",
          "name": "name_lit"
        }
      ]
    },
    "num_lit": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "PATTERN",
            "value": "0[xX][0-9a-fA-F](_?[0-9a-fA-F])*"
          },
          {
            "type": "PATTERN",
            "value": "0[oO][0-7](_?[0-7])*"
          },
          {
            "type": "PATTERN",
            "value": "0[bB][01](_?[01])*"
          },
          {
            "type": "PATTERN",
            "value": "[0-9](_?[0-9])*"
          }
        ]
      }
    },
    "scientific_lit": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "PATTERN",
            "value": "[0-9](_?[0-9])*\\.[0-9]?(_?[0-9])*([eE][+-]?[0-9](_?[0-9])*)?"
          },
          {
            "type": "PATTERN",
            "value": "[0-9](_?[0-9])*[eE][+-]?[0-9](_?[0-9])*"
          }
        ]
      }
    },
    "char_lit": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "'"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "escape_sequence"
            },
            {
              "type": "PATTERN",
              "value": "[^'\\\\\\n]"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "'"
        }
      ]
    },
    "str_lit": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "\""
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "escape_sequence"
              },
              {
                "type": "IMMEDIATE_TOKEN",
                "content": {
                  "type": "PREC",
                  "value": 1,
                  "content": {
                    "type": "PATTERN",
                    "value": "[^\"\\\\\\n]+"
                  }
                }
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": "\""
        }
      ]
    },
    "escape_sequence": {
      "type": "IMMEDIATE_TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "\\"
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "PATTERN",
                "value": "[\\\\\"'rnt0]"
              },
              {
                "type": "PATTERN",
                "value": "x[0-9a-fA-F]{2}"
              },
              {
                "type": "PATTERN",
                "value": "u[0-9a-fA-F]{4}"
              },
              {
                "type": "PATTERN",
                "value": "u\\{[0-9a-fA-F]+\\}"
              }
            ]
          }
        ]
      }
    },
    "interpolated_str": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_interp_open"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "escape_sequence"
              },
              {
                "type": "SYMBOL",
                "name": "interpolation"
              },
              {
                "type": "IMMEDIATE_TOKEN",
                "content": {
                  "type": "PREC",
                  "value": 1,
                  "content": {
                    "type": "PATTERN",
                    "value": "[^\"\\\\\\{\\n]+"
                  }
                }
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": "\""
        }
      ]
    },
    "_interp_open": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "s!\""
        },
        {
          "type": "STRING",
          "value": "m!\""
        }
      ]
    },
    "interpolation": {
      "type": "SEQ",
      "members": [
        {
          "type": "IMMEDIATE_TOKEN",
          "content": {
            "type": "STRING",
            "value": "{"
          }
        },
        {
          "type": "SYMBOL",
          "name": "_term"
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "name_lit": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "`"
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          }
        }
      ]
    },
    "line_comment": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "--"
          },
          {
            "type": "PATTERN",
            "value": "[^\\n]*"
          }
        ]
      }
    },
    "_wordToken": {
      "type": "PATTERN",
      "value": "[a-zA-Z_][a-zA-Z_0-9]*"
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    },
    {
      "type": "SYMBOL",
      "name": "line_comment"
    },
    {
      "type": "SYMBOL",
      "name": "block_comment"
    },
    {
      "type": "SYMBOL",
      "name": "doc_comment"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [
    {
      "type": "SYMBOL",
      "name": "identifier"
    },
    {
      "type": "SYMBOL",
      "name": "block_comment"
    },
    {
      "type": "SYMBOL",
      "name": "doc_comment"
    },
    {
      "type": "SYMBOL",
      "name": "module_doc_comment"
    },
    {
      "type": "SYMBOL",
      "name": "raw_string"
    },
    {
      "type": "SYMBOL",
      "name": "error_sentinel"
    }
  ],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}
