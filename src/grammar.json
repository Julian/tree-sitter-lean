        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "prelude"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "import"
          }
        }
      ]
    },
    "moduleTk": {
      "type": "STRING",
      "value": "module"
    },
    "prelude": {
      "type": "STRING",
      "value": "prelude"
    },
    "import": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "public"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "meta"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "import"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "all"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          }
        }
      ]
    },
    "public": {
      "type": "STRING",
      "value": "public"
    },
    "meta": {
      "type": "STRING",
      "value": "meta"
    },
    "all": {
      "type": "STRING",
      "value": "all"
