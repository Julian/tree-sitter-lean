            "members": [
              {
                "type": "IMMEDIATE_TOKEN",
                "content": {
                  "type": "STRING",
                  "value": "."
                }
              },
              {
                "type": "IMMEDIATE_TOKEN",
                "content": {
                  "type": "PATTERN",
                  "value": "[A-Za-z_][A-Za-z_0-9'!?]*"
                }
              }
            ]
          }
        }
      ]
    },
    "_identComponent": {
      "type": "PATTERN",
      "value": "[A-Za-z_][A-Za-z_0-9'!?]*"
    }
  },
  "extras": [
